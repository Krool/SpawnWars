{
  "rules": {
    // Deny everything by default
    ".read": false,
    ".write": false,

    "parties": {
      // Allow querying parties by status (for matchmaking)
      ".indexOn": ["status"],

      // Allow listing parties for findAndJoinGame query
      ".read": "auth != null",

      "$code": {
        // Anyone authenticated can read a specific party
        ".read": "auth != null",

        // Allow creation: authenticated user, party must not already exist
        // Allow full delete by the host only
        ".write": "auth != null && (
          (!data.exists() && newData.exists()) ||
          (data.exists() && data.child('hostUid').val() === auth.uid && !newData.exists())
        )",

        // Validate overall party structure
        ".validate": "newData.hasChildren(['code', 'hostUid', 'host', 'status', 'seed'])",

        "code": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 6"
        },
        "hostUid": {
          ".validate": "newData.isString() && newData.val().length <= 128"
        },
        "seed": {
          ".validate": "newData.isNumber()"
        },
        "status": {
          // Only host can change status
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isString() && (
            newData.val() === 'waiting' ||
            newData.val() === 'starting' ||
            newData.val() === 'in_game' ||
            newData.val() === 'ended'
          )"
        },
        "difficulty": {
          // Only host can set difficulty
          ".write": "auth != null && data.parent().child('hostUid').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "host": {
          // Only host can update their own data
          ".write": "auth != null && (
            data.parent().child('hostUid').val() === auth.uid ||
            !data.parent().exists()
          )",
          ".validate": "newData.hasChildren(['uid', 'name', 'race'])",
          "uid": { ".validate": "newData.isString() && newData.val().length <= 128" },
          "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
          "race": { ".validate": "newData.isString() && newData.val().length <= 20" }
        },
        "guest": {
          // Guest can write their own slot (set or remove)
          // Host can also remove guest (when destroying party)
          ".write": "auth != null && (
            !data.exists() ||
            data.child('uid').val() === auth.uid ||
            data.parent().child('hostUid').val() === auth.uid
          )",
          ".validate": "newData.hasChildren(['uid', 'name', 'race'])",
          "uid": { ".validate": "newData.isString() && newData.val().length <= 128" },
          "name": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 30" },
          "race": { ".validate": "newData.isString() && newData.val().length <= 20" }
        }
      }
    },

    "games": {
      "$code": {
        // Anyone authenticated who knows the code can read/write game data
        // The 5-char party code acts as a shared secret
        ".read": "auth != null",

        "ready": {
          "$slot": {
            ".write": "auth != null && ($slot === '0' || $slot === '1')",
            ".validate": "newData.isBoolean()"
          }
        },
        "turns": {
          "$turn": {
            "$slot": {
              ".write": "auth != null && ($slot === '0' || $slot === '1')",
              // Limit turn data size: cmds array + hash + turn number
              ".validate": "newData.hasChild('t') && newData.child('t').isNumber()"
            }
          }
        },
        "ping": {
          "$slot": {
            ".write": "auth != null && ($slot === '0' || $slot === '1')",
            ".validate": "newData.isNumber()"
          }
        }
      }
    }
  }
}
